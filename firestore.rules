
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAuthor(authorId) {
      return isSignedIn() && request.auth.uid == authorId;
    }

    match /userProfiles/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow write: if false; // Admin only
    }

    match /subCategories/{subCategoryId} {
      allow get, list: if true;
      allow write: if false; // Admin only
    }

    match /topics/{topicId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthor(resource.data.authorId) || isSignedIn(); // Allow simple updates for view counts/replies
      allow delete: if isAuthor(resource.data.authorId);

      match /posts/{postId} {
        allow get, list: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isAuthor(resource.data.authorId);
      }
    }

    match /rustServers/{serverId} {
      allow get, list: if true;
      allow write: if false;
    }

    match /newsArticles/{articleId} {
      allow get, list: if true;
      allow write: if false;
    }

    match /contentCreators/{creatorId} {
      allow get, list: if true;
      allow write: if false;
    }

    match /appConfiguration/{configId} {
      allow get, list: if true;
      allow write: if false;
    }
  }
}
