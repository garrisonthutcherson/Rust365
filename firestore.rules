rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for security and readability
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAuthor(authorId) {
      return isSignedIn() && request.auth.uid == authorId;
    }

    // User Profile Rules
    match /userProfiles/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Board Structure (Seeding allowed for any authenticated user for now)
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /subCategories/{subCategoryId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Discussion Topics and Replies
    match /topics/{topicId} {
      // Explicitly allow reading topics for everyone
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      // Allow updates for stats (view counts, reply counts) or by the author
      allow update: if isSignedIn();
      allow delete: if isAuthor(resource.data.authorId);

      // Nested Posts (Replies)
      match /posts/{postId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isAuthor(resource.data.authorId);
      }
    }

    // Game-specific content and configurations
    match /rustServers/{serverId} {
      allow read: if true;
      allow write: if false;
    }

    match /newsArticles/{articleId} {
      allow read: if true;
      allow write: if false;
    }

    match /contentCreators/{creatorId} {
      allow read: if true;
      allow write: if false;
    }

    match /appConfiguration/{configId} {
      allow read: if true;
      allow write: if false;
    }
  }
}